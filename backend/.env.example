PORT=5000
MONGO_URI=mongodb://localhost:27017/suppx
JWT_SECRET=your_super_secret_jwt_key_here_change_this
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Razorpay ─────────────────────────────────────────────────────────────────
